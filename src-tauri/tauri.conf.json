{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pitch Gauge",
  "version": "0.1.0",
  "identifier": "io.bidlist.pitchgauge",
  "build": {
    "frontendDist": "../src",
    "beforeBuildCommand": "npm run build:js"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pitch Gauge",
        "width": 560,
        "height": 440,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "signingIdentity": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4M0E3MjE1REUzRkVBMUUKUldRZTZqL2VGWEk2eUlNRkJ3L2hYRFVzNnNhTUxIK1V6TjBjdk04MFlnYkptcnNTWVZZK211dm4K",
      "endpoints": [
        "https://example.com/pitch-gauge/updates/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
